{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@hyprcode/contracts": [
        "./packages/contracts/src/index.ts"
      ],
      "@hyprcode/shared": [
        "./packages/shared/src/index.ts"
      ],
      "@hyprcode/ui": [
        "./packages/ui/src/index.tsx"
      ]
    }
  }
}

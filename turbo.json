{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "HYPRCODE_SERVER_PORT",
    "HYPRCODE_SERVER_URL",
    "HYPRCODE_STATE_DIR",
    "HYPRCODE_DESKTOP_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "dist-electron/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "^test"
      ],
      "outputs": []
    }
  }
}
